# Root .gitignore
cat > .gitignore << 'EOF'
# Environment variables
.env
.env.local
.env.*.local
.env.production
.env.development

# Node modules
node_modules/
npm-debug.log*

# Build outputs
dist/
build/

# IDE
.vscode/
.idea/
*.swp

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db

# Docker
.dockerignore

# Database
*.db
*.sqlite
EOF
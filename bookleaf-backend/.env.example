# Server Operations Configuration
PORT=5000
NODE_ENV=development

# Database Interconnect Parameters
DATABASE_URL=postgresql://db_user:db_password@localhost:5432/bookleaf_db
REDIS_URL=redis://localhost:6379

# Cryptographic Token Signing Secrets
JWT_SECRET=replace_this_with_a_secure_long_random_entropy_string_constant
JWT_EXPIRES_IN=7d

# Third-Party AI Engine Credentials
CLAUDE_API_KEY=your_anthropic_claude_api_credential_token